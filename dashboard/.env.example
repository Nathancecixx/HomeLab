# Public port exposed by docker compose.
HTTP_PORT=8080

# The mounted homelab repo root inside the container/runtime.
HOMELAB_ROOT=/homelab

# Host root mount used for host-aware telemetry.
HOST_FS_ROOT=/hostfs

# Generate with:
# node -e "import bcrypt from 'bcryptjs'; bcrypt.hash('change-me', 12).then(console.log)"
ADMIN_PASSWORD_BCRYPT=

# Use a long random secret in production.
SESSION_SECRET=change-me
SESSION_TTL_SECONDS=43200
COOKIE_SECURE=false

TELEMETRY_FAST_MS=2000
TELEMETRY_SLOW_MS=10000
TELEMETRY_HISTORY_POINTS=36

# Wake-on-LAN targets are read from this file at runtime.
WOL_TARGETS=LAN_SERVER
WOL_TARGET_LAN_SERVER_LABEL=External LAN Server
WOL_TARGET_LAN_SERVER_MAC=AA:BB:CC:DD:EE:FF
WOL_TARGET_LAN_SERVER_IP=192.168.1.50
WOL_TARGET_LAN_SERVER_BROADCAST=192.168.1.255
WOL_TARGET_LAN_SERVER_PORT=9
